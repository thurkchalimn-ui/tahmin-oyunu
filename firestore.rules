rules_version = '2';

// Güvenlik notu: Seri (streak) yeniden hesaplama işlemi bu MVP'de admin
// istemcisi tarafından tetiklenir. Üretimde kopyalanamaz/hile yapılamaz
// olması için bu mantığın bir Cloud Function'a taşınması önerilir
// (bkz. proje README'sindeki "Sonraki Geliştirme Adımı").
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // admins koleksiyonu: sadece Firebase Console üzerinden manuel eklenir,
    // istemciden asla yazılamaz.
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // users/{uid}: herkes liderlik tablosu için okuyabilir.
    // Sahibi sadece displayName günceller; seri/rozet alanlarını yalnız admin değiştirir.
    match /users/{uid} {
      allow read: if true;
      allow create: if isOwner(uid);
      allow update: if isAdmin() ||
        (isOwner(uid) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['displayName', 'updatedAt', 'lastSeenChatAt', 'lastSeenRank', 'lastSeenProfileAt', 'fcmTokens', 'avatarUrl']));
      allow delete: if false;
    }

    // usernames/{normalizedName}: kullanıcı adı benzersizliğinin GERÇEK garantisi
    // burada sağlanır. Doküman ID'si normalize edilmiş kullanıcı adıdır - bir isim
    // zaten alınmışsa doküman zaten var demektir, bu durumda "create" değil "update"
    // kuralına düşer ve `allow update: if false` bunu otomatik olarak engeller.
    // Böylece iki kullanıcı aynı anda aynı ismi almaya çalışsa bile sadece biri başarılı olur.
    match /usernames/{key} {
      allow read: if true;
      allow create: if isOwner(request.resource.data.uid);
      allow update: if false;
      allow delete: if isOwner(resource.data.uid);
    }

    // matches/{matchId}: herkes okuyabilir, sadece admin yazar/düzenler.
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // teamLogos/{normalizedTeamName}: daha önce eklenmiş takımların logo
    // hafızası. Admin panelindeki "takım adı yazınca logo otomatik gelsin"
    // özelliği için kullanılır; herkes okuyabilir, sadece admin yazar.
    match /teamLogos/{teamKey} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // avatarOptions/{key}: admin tarafından belirlenen, kullanıcıların profil
    // avatarı olarak seçebileceği sabit logo listesi. Kullanıcılar sadece bu
    // listeden seçer, kendi görsel linki giremez; herkes okuyabilir, sadece admin yazar.
    match /avatarOptions/{key} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // notificationQueue/{id}: admin panelinden elle bir maç sonucu girildiğinde
    // buraya bir "gönderilmesi gereken bildirim" kaydı bırakılır. İstemci
    // doğrudan başka bir kullanıcıya push gönderemediği için gerçek gönderim,
    // Admin SDK'ya sahip GitHub Actions otomasyon script'i tarafından yapılır
    // (bkz. automation/check-results.js) - o da bu koleksiyonu okuyup temizler.
    match /notificationQueue/{id} {
      allow read: if false;
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // predictions/{predictionId}: kullanıcı sadece kendi tahminini,
    // maç henüz kilitlenmemişken (kickoffAt gelecekte) VE e-postasını
    // doğrulamışken oluşturabilir. isCorrect alanı yalnız admin tarafından
    // (sonuç girildiğinde) güncellenir.
    // GÜVENLİK NOTU: Günlük tahmin hakkı limiti (5 ücretsiz + reklamla kazanılan
    // bonus, en fazla 20) bu MVP'de yalnızca istemci tarafında (arayüzde)
    // uygulanmaktadır. Tam sunucu taraflı doğrulama bir Cloud Function/transaction
    // gerektirir; bkz. bu dosyanın başındaki benzer not (seri hesaplaması için).
    match /predictions/{predictionId} {
      allow read: if true;
      allow create: if isOwner(request.resource.data.userId) &&
        request.resource.data.isCorrect == null &&
        request.resource.data.date is string &&
        request.auth.token.email_verified == true;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // dailyBonusCredits/{uid}_{date}: kullanıcı, reklam izleyerek kazandığı
    // günlük ekstra tahmin hakkını burada biriktirir. Her yazımda tam olarak
    // +1 artabilir ve en fazla 15'e (5 temel hak + 15 = 20 tavan) ulaşabilir;
    // böylece bir kullanıcı isteği manipüle etse bile sınırsız hak biriktiremez.
    match /dailyBonusCredits/{docId} {
      allow read: if true;
      allow create: if isOwner(request.resource.data.userId) &&
        request.resource.data.credits == 1;
      allow update: if isOwner(resource.data.userId) &&
        request.resource.data.credits == resource.data.credits + 1 &&
        request.resource.data.credits <= 15;
      allow delete: if false;
    }
    // messages/{messageId}: herkes okuyabilir (giriş yapmasa bile), sadece
    // e-postasını doğrulamış kullanıcılar kendi adına mesaj gönderebilir.
    // Mesajlar bir kez gönderildikten sonra değiştirilemez/silinemez (moderasyon
    // gerekirse admin panelinden Firestore Console üzerinden manuel silinebilir).
    match /messages/{messageId} {
      allow read: if true;
      allow create: if isOwner(request.resource.data.userId) &&
        request.auth.token.email_verified == true &&
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0 &&
        request.resource.data.text.size() <= 500 &&
        request.resource.data.isAdmin == isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }
  }
}
