# Firebase proje ayarları (Firebase Console > Project Settings > General > SDK config)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Admin yetkisi verilecek kullanıcı e-postaları (virgülle ayrılmış)
# Bu liste sadece istemci tarafı UI kontrolü içindir; gerçek yetkilendirme
# Firestore Security Rules üzerinden yapılmalıdır (bkz. firestore.rules)
VITE_ADMIN_EMAILS=admin@example.com

# Google AdMob (ileride mobil sürüm - Capacitor/React Native köprüsü için hazır alan)
VITE_ADMOB_APP_ID=
VITE_ADMOB_BANNER_ID=

# Push bildirimleri (Firebase Cloud Messaging - Web Push sertifikası)
# Firebase Console > Project Settings > Cloud Messaging > Web Push certificates > Generate key pair
VITE_FIREBASE_VAPID_KEY=
